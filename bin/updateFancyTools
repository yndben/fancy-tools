#!/bin/bash
set -e

SRC_DIR=/home/yanid/src/fancy_tools

echo "=== Mise a jour de fancy_tools ==="

cd $SRC_DIR

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
    echo "Erreur : pas sur la branche main"
    exit 1
fi

git pull
echo "[OK] Depot mis a jour"

echo "=== Mise a jour terminee ! ==="
