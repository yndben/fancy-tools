#!/bin/bash
set -e

SRC_DIR=~/src/fancy_tools

echo "=== Mise à jour de fancy_tools ==="

cd "$SRC_DIR

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
    echo "Erreur : vous n'êtes pas sur la branche main (branche actuelle : $BRANCH)"
    exit 1
fi

git pull
echo "[OK] Dépôt mis à jour"

cp "$SRC_DIR/bin/updateFancyTools" ~/bin/updateFancyTools
chmod +x ~/bin/updateFancyTools
echo "[OK] updateFancyTools mis à jour dans ~/bin"

echo "=== Mise à jour terminée ! ==="

